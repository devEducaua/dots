global-section-name all
notification-command "notify-send '%q: feeds updates'" 

unbind v
unbind e

bind e view-errors
bind v exec mpv "%l"
bind f exec ~/.config/Scripts/nsxiv-url.sh "%l"
bind n exec open-in-browser-command nvim "%c"
bind z exec open-in-browser-command zen-browser -new-tab %l
bind y exec 'echo "%l" | xclip -sel clip'

bind K toggle-read
bind J mark-read; jump-to-next
bind do exec 'yt-dlp --write-auto-subs --sub-format srt --sub-langs en "%l"'

color-status black color245

color-list-section color250
color-list-section-selected black color250
color-list-section-unread bold color250

color-list-feed color250
color-list-feed-selected black color250 
color-list-feed-unread bold color250

color-list-item color250
color-list-item-selected black color250 
color-list-item-unread bold color250
